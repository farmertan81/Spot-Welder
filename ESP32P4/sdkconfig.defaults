# ===== LVGL configuration for the spot-welder UI (ui.cpp) =====
# NOTE: these defaults only apply to a FRESH config. If you have already built
# once, the generated `sdkconfig` already has the old values and will WIN over
# this file. Do NOT just delete `sdkconfig` (that would also wipe your PSRAM /
# flash-size / target settings, which live only in `sdkconfig`). Instead, apply
# the LVGL changes below via:  idf.py menuconfig
#   Component config -> LVGL configuration -> Memory Settings
#     -> set the allocator to "C library's malloc/free"  (LV_USE_CLIB_MALLOC)
# then: idf.py -p COM6 build flash monitor

# Color depth must match the RGB panel (RGB565)
CONFIG_LV_COLOR_DEPTH_16=y

# Fonts used by ui.cpp
CONFIG_LV_FONT_MONTSERRAT_14=y
CONFIG_LV_FONT_MONTSERRAT_16=y
CONFIG_LV_FONT_MONTSERRAT_18=y
CONFIG_LV_FONT_MONTSERRAT_20=y
CONFIG_LV_FONT_MONTSERRAT_24=y
CONFIG_LV_FONT_MONTSERRAT_48=y
CONFIG_LV_FONT_DEFAULT_MONTSERRAT_14=y

# Widgets / extras used by ui.cpp
CONFIG_LV_USE_TABVIEW=y
CONFIG_LV_USE_SPINBOX=y
CONFIG_LV_USE_BAR=y
CONFIG_LV_USE_QRCODE=y

# ===== LVGL memory allocator =====
# The 5-tab 800x480 UI needs far more than the 64 KB builtin LVGL pool. When
# the builtin pool overflows mid-build, lv_malloc() fails, LV_ASSERT_MALLOC
# spins forever, and the task watchdog reboots the chip (~5 s after touch init).
# Use the C-library allocator instead so LVGL draws from the system heap, which
# already includes the 32 MB PSRAM pool (see "Adding pool of 32768K of PSRAM
# memory to heap allocator" in the boot log). This eliminates the OOM crash.
CONFIG_LV_USE_CLIB_MALLOC=y
# (LV_MEM_SIZE_KILOBYTES only applies to the builtin allocator, which is now
#  disabled, so it is intentionally omitted.)
#
# --- PSRAM allocation strategy (fixes WiFi-induced glitching) ---
# LVGL's draw buffers (moved to PSRAM in welder_main.cpp) free ~150 KB of
# internal RAM, but LVGL objects themselves are still malloc'd and can exhaust
# internal RAM when WiFi is active. Route large allocations (>= 16 KB) to PSRAM
# automatically, keeping small/DMA-critical allocations (WiFi, lwIP, drivers)
# in internal RAM. This eliminates the screen glitching that appeared when the
# WiFi stack came up and competed for internal RAM.
CONFIG_SPIRAM_USE_MALLOC=y
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=16384
# Explicitly keep WiFi/lwIP buffers in internal RAM (they need it for DMA).
CONFIG_SPIRAM_TRY_ALLOCATE_WIFI_LWIP=y

# ===== RTOS tick rate =====
# Run the FreeRTOS tick at 1000 Hz (1 ms/tick) instead of the 100 Hz default.
# The LVGL task loops with vTaskDelay(pdMS_TO_TICKS(5)); at 100 Hz that rounds
# DOWN to 0 ticks, so vTaskDelay(0) never blocks — the lower-priority IDLE0
# task on CPU0 is starved, the task watchdog is never fed, and it trips
# repeatedly (the "IDLE0 (CPU 0)" watchdog crash). At 1000 Hz the 5 ms delay
# blocks for a real 5 ticks, IDLE0 runs, and LVGL also gets finer timing for
# smoother rendering. (The code in welder_main.cpp also clamps the delay to a
# minimum of 1 tick as a belt-and-suspenders guard regardless of this setting.)
CONFIG_FREERTOS_HZ=1000

# ===== Runtime: task watchdog =====
# Generous timeout to survive the first full-screen software paint of the
# large 5-tab 800x480 UI at boot. With the LVGL task now yielding correctly
# (see FREERTOS_HZ above + the 1-tick delay clamp) the watchdog should never
# trip in steady state.
CONFIG_ESP_TASK_WDT_TIMEOUT_S=60
# NOTE: do NOT enable CONFIG_ESP_SYSTEM_USE_FRAME_POINTER here. It is applied to
# the bootloader build too and pushes the bootloader binary past its 24 KB cap
# (build error: "Bootloader binary size 0x61a0 ... too large"). It also adds
# per-function runtime overhead, which slows the already-heavy software render.
# Apply the watchdog timeout via: idf.py menuconfig
#   Component config -> ESP System Settings
#     -> Task Watchdog timeout period (seconds)        = 30

# ===== WiFi / radio (ESP32-P4 + onboard ESP32-C6) =====
# The ESP32-P4 has NO native WiFi radio. On this CrowPanel board the radio is
# the onboard ESP32-C6, reached over SDIO via the esp_hosted / esp_wifi_remote
# managed components (declared in main/idf_component.yml). The standard esp_wifi
# API in wifi_bridge.cpp works transparently through that link.
#
# --- ESP-Hosted SDIO transport pins (CrowPanel Advance ESP32-P4 5" V1.0) ---
# CRITICAL: the esp_hosted defaults (CLK18 CMD19 D0-14..D3-17, reset GPIO54
# active-low) are for Espressif's own P4 EV board and are WRONG for this
# CrowPanel. With the wrong pins the C6 never answers and the boot log shows:
#     E SD_HOST: sd_host_start_command returned 0x107   (0x107 = TIMEOUT)
#     E sdio_wrapper: sdmmc_card_init failed
#     E transport: ensure_slave_bus_ready failed / "ESP-Hosted link not yet up"
#
# The values below are taken verbatim from Elecrow's official CrowPanel ESP-IDF
# example (Squareline_LVGL_LED/sdkconfig.defaults) and Arduino board_config.h,
# cross-checked against the V1.0 schematic. Reset is GPIO20 ACTIVE-HIGH.
# These CONFIG_ESP_HOSTED_* symbols are provided by the esp_hosted managed
# component (declared in main/idf_component.yml), so they resolve fine here —
# unlike the native-WiFi CONFIG_ESP_WIFI_* symbols that broke an earlier build.
CONFIG_ESP_HOSTED_ENABLED=y
CONFIG_ESP_HOSTED_PRIV_SDIO_OPTION=y
CONFIG_ESP_HOSTED_IDF_SLAVE_TARGET="esp32c6"
CONFIG_ESP_HOSTED_SDIO_RESET_ACTIVE_HIGH=y
CONFIG_ESP_HOSTED_SDIO_SLOT_1=y
CONFIG_ESP_HOSTED_SDIO_4_BIT_BUS=y
CONFIG_ESP_HOSTED_SDIO_CLOCK_FREQ_KHZ=40000
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_CMD_SLOT_1=54
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_CLK_SLOT_1=53
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_D0_SLOT_1=52
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_D1_4BIT_BUS_SLOT_1=51
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_D2_4BIT_BUS_SLOT_1=50
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_D3_4BIT_BUS_SLOT_1=49
CONFIG_ESP_HOSTED_SDIO_GPIO_RESET_SLAVE=20
#
# Boot log should now print: CLK[53] CMD[54] D0[52] D1[51] D2[50] D3[49]
# Slave_Reset[20]. If the C6 still won't enumerate, its factory slave firmware
# (esp_hosted v2.3.0) is buggy on SDIO — drop to 1-bit bus (set
# CONFIG_ESP_HOSTED_SDIO_4_BIT_BUS=n) and/or 20 MHz, or update the C6 firmware
# (see crowpanel-p4-c6-sdio-ota). wifi_stack_init() already treats a failed link
# as NON-FATAL so the welder UI keeps running either way.
#
# WiFi station+AP (provisioning) mode is enabled at runtime by wifi_bridge.cpp;
# buffer settings use ESP-IDF defaults — tune via menuconfig if needed.

# ===== Flash Size =====
# CrowPanel P4 has 16 MB flash (verify via: esptool.py --port COM6 flash_id).
# The default 2 MB setting in a fresh sdkconfig is wrong and causes partition
# table overflow errors when the factory app is 2 MB.
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y

# ===== Partition Table =====
# The full WiFi provisioning + HTTP server + captive portal + mDNS pushed the
# binary past the default 1 MB factory partition (actual size ~1.27 MB). Use a
# custom partition table (partitions.csv) with a 2 MB factory app.
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# ===== RGB LCD anti-glitch / anti-drift (fixes shifting lines under WiFi load) =====
# Symptom: with WiFi active, horizontal lines on the 800x480 RGB panel drift /
# shift. Root cause: the RGB peripheral streams the PSRAM framebuffer through an
# internal-RAM bounce buffer via GDMA. When WiFi DMA + cache misses steal PSRAM
# bandwidth, the bounce buffer underruns and the scan-out loses alignment.
#
# NOTE: CONFIG_LCD_RGB_RESTART_IN_VSYNC was tried and made the drift WORSE in
# our single-framebuffer partial-render setup (it forces a hard DMA realignment
# mid-scanout that is visible as a jump). It is intentionally NOT set. The real
# cure is the VSYNC-synced double framebuffer in welder_main.cpp (num_fbs=2 +
# avoid-tearing draw), matching the proven Elecrow WiFi+display reference.
#
# Keep the GDMA control path and ISR handler in IRAM so the bounce-buffer
# refill keeps running even when the flash/PSRAM cache is briefly disabled
# (e.g. during WiFi/NVS flash writes). Matches the reference (Lesson16).
CONFIG_GDMA_CTRL_FUNC_IN_IRAM=y
CONFIG_GDMA_ISR_HANDLER_IN_IRAM=y
CONFIG_GDMA_OBJ_DRAM_SAFE=y
