{
  "version": "2.0.0",
  "tasks": [
    {
      // Push the already-built firmware to the device over WiFi (no USB).
      // This is the ESP-IDF equivalent of PlatformIO's espota upload.
      // Build first with the ESP-IDF "Build" button, then run this task.
      "label": "Flash over WiFi (OTA)",
      "type": "shell",
      "command": "python",
      "args": ["${workspaceFolder}/tools/ota_flash.py"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      // Same as above but lets you type/override the device host (IP or mDNS).
      "label": "Flash over WiFi (OTA) — choose host",
      "type": "shell",
      "command": "python",
      "args": ["${workspaceFolder}/tools/ota_flash.py", "${input:otaHost}"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      // Send a freshly built STM32 firmware image to the ESP32 over WiFi; the
      // ESP32 then flashes the STM32 over UART (AN3155). Build the STM32 in
      // PlatformIO first; this auto-finds STM32G474CE/.pio/build/*/firmware.bin.
      "label": "Flash STM32 over WiFi",
      "type": "shell",
      "command": "python",
      "args": ["${workspaceFolder}/tools/stm32_flash_wifi.py"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      // Same as above but lets you type the device host and/or the .bin path.
      "label": "Flash STM32 over WiFi — choose host",
      "type": "shell",
      "command": "python",
      "args": ["${workspaceFolder}/tools/stm32_flash_wifi.py", "${input:otaHost}"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      // ONE-CLICK: Build STM32 firmware (PlatformIO) + flash it wirelessly.
      // This is the complete end-to-end workflow: edit STM32 code -> run this task.
      "label": "Build & Flash STM32 (PlatformIO + WiFi)",
      "dependsOn": ["Build STM32 firmware (PlatformIO)", "Flash STM32 over WiFi"],
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      // Sub-task: Build the STM32 firmware using PlatformIO CLI.
      // The STM32G474CE project is a sibling to ESP32P4.
      "label": "Build STM32 firmware (PlatformIO)",
      "type": "shell",
      "command": "pio",
      "args": ["run", "-d", "${workspaceFolder}/../STM32G474CE", "-e", "g474ceu6_stlink"],
      "problemMatcher": ["$platformio"],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      }
    }
  ],
  "inputs": [
    {
      "id": "otaHost",
      "type": "promptString",
      "description": "Device host (IP or mDNS name)",
      "default": "192.168.1.77"
    }
  ]
}
